{
  "manifest_version": 3,
  "name": "NinjaCrawler Companion",
  "description": "Adds and syncs supported social profiles with NinjaCrawler from the current browser tab.",
  "version": "0.2.1",
  "action": {
    "default_popup": "popup.html",
    "default_title": "NinjaCrawler Companion"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": ["activeTab", "cookies", "scripting", "storage", "tabs", "webRequest"],
  "host_permissions": [
    "http://127.0.0.1:47219/*",
    "http://localhost:47219/*",
    "https://*.instagram.com/*",
    "https://x.com/*",
    "https://*.x.com/*",
    "https://twitter.com/*",
    "https://*.twitter.com/*",
    "https://tiktok.com/*",
    "https://*.tiktok.com/*"
  ]
}
